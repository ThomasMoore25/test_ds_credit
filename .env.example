# Пример переменных окружения для credit_check.
# Скопируй в .env и заполни значениями:
#   cp .env.example .env

# Опционально: ключ OpenAI для LLM-движка в check_subject().
# Без него check_subject использует keyword + fuzzy fallback — код работает локально.
# OPENAI_API_KEY=sk-...

# Опционально: модель OpenAI (по умолчанию gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
